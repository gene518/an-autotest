{
  "name": "an-autotest",
  "version": "1.0.0",
  "description": "Playwright automation tests for jk.cn IM application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "playwright test; npx playwright show-report \"$(ls -1dt test-results/*/html-report 2>/dev/null | head -1)\"",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "codegen": "playwright codegen https://www.jk.cn"
  },
  "keywords": [
    "playwright",
    "automation",
    "testing"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^25.5.0"
  }
}
